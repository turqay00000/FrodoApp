# JARVIS PRO Configuration
# Ortam Değişkenleri

# Flask Configuration
JARVIS_HOST=0.0.0.0
JARVIS_PORT=5000
JARVIS_DEBUG=True

# Ollama Configuration
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# Whisper (Speech-to-Text)
WHISPER_MODEL=base
WHISPER_LANGUAGE=tr

# Piper (Text-to-Speech)
PIPER_VOICE=en_US-ryan-medium
PIPER_SPEAKER=0
PIPER_LENGTH_SCALE=1.0

# Open Interpreter
OI_TIMEOUT=30
OI_AUTO_RUN=false

# API Keys (gerekirse)
OPENAI_API_KEY=
GROQ_API_KEY=

# Paths
JARVIS_ROOT=/opt/jarvis-pro
PROJECTS_DIR=$HOME/JARVIS-Projects
LOG_DIR=$JARVIS_ROOT/logs

# Database (opsiyonel)
DATABASE_URL=sqlite:///$JARVIS_ROOT/jarvis.db

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Security
SECRET_KEY=your-secret-key-change-this-in-production
JWT_SECRET=your-jwt-secret-change-this-in-production

# Features
ENABLE_CURSOR=true
ENABLE_TERMINAL=true
ENABLE_BROWSER=true
ENABLE_FILE_MANAGER=true
ENABLE_OPEN_INTERPRETER=true

# Türkçe Dil Desteği
LANGUAGE=tr
LOCALE=tr_TR.UTF-8

# Dev Mode
DEBUG=true
FLASK_ENV=development
